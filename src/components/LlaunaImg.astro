---
interface Props {
    flavour: string;
    side: string;
}

const {flavour="uvas", side="front"} = Astro.props;

const sourceavif = `/pagina-llaunes/img/${flavour}/${side}.avif`;
const sourcewebp = `/pagina-llaunes/img/${flavour}/${side}.webp`;
const sourcejpg = `/pagina-llaunes/img/${flavour}/${side}.jpg`;
const sourcepng = `/pagina-llaunes/img/${flavour}/${side}.png`;
const altTxt = `Llauna de ${flavour}`
---

<div class="md:w-64 w-40 lata-deco order-1">
    <picture>
        <source srcset={sourceavif} type="image/avif"/>
        <source srcset={sourcewebp} type="image/webp"/>
        <source srcset={sourcejpg} type="image/jpeg"/>
        <img src={sourcepng} alt={altTxt}/>
    </picture>
</div>