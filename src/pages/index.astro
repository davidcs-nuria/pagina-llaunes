---
import LlaunaLink from "../components/LlaunaLink.astro";
import Layout from "../layouts/Layout.astro";
import "../styles/global.css";
import 'animate.css';
---

<Layout>
	<div class="flex w-screen justify-center bg-stone-800 mb-10">
		<div class="md:top-120 top-67 absolute text-white text-shadow-lg bg-stone-700 md:p-2 p-1"><a href="#" class="relative object-cover">Compra ara</a></div>
		<video src="/pagina-llaunes/video/header.webm" class="w-[500px] md:w-[800px]" autoplay loop></video>
	</div>
	<h1 class="text-center mb-6 font-bold text-3xl text-white">LES NOSTRES BEGUDES</h1>
	<div class="flex flex-row justify-center md:gap-10 gap-3 flex-wrap">
		<div class="md:gap-10 gap-3 flex flex-row">
			<LlaunaLink
				flavour="mango"
				side="frente"/>
			<LlaunaLink 
				flavour="coco"
				side="frente"/>
			<LlaunaLink
				flavour="manzana"
				side="frente"/>
		</div>
		<div class="md:gap-10 gap-3 flex flex-row">
			<LlaunaLink
				flavour="pitahaya"
				side="frente"/>
			<LlaunaLink
				flavour="taronja"
				side="frente"/>
			<LlaunaLink
				flavour="uves"
				side="frente"/>
		</div>
	</div>
</Layout>
