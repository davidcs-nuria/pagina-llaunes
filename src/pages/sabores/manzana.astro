---
import LlaunaImg from "../../components/LlaunaImg.astro";
import LlaunaLink from "../../components/LlaunaLink.astro";
import Layout from "../../layouts/Layout.astro";
import "../../styles/global.css";
import 'animate.css';
---

<Layout>
    <div class="flex flex-row m-5 gap-10 justify-center items-center">
        <div class="text-white text-right align-center h-[90%] w-[40%]">
            <p class="font-bold sm:text-2xl text-xl mulish-bold">STORMCHARGE POMA</p>
            <p class="sm:text-sm text-xs mulish-thin">Lorem ipsum dolor sit amet consectetur adipisicing elit. Omnis excepturi maiores minima a quae temporibus molestias quasi tempore. Quos reiciendis ab quod qui voluptates aspernatur. Illo animi accusamus at sit.</p>
            <br>
            <a href="#" class="bg-[#D0E07D] text-[#A5C04F] font-bold sm:text-md text-sm hover:text-white p-2 transition-[0.2s] mulish-bold">ON TROBAR</a>
        </div>
        <div class="flex">
            <LlaunaImg
                flavour="manzana"
                side="frente"/>
        </div>
    </div>

    <section class="parallax-section">
        <div class="flex justify-center m-30 text-white">
        <div class="flex flex-col bg-stone-600 text-right p-20">
            <p class="font-bold text-2xl align-right mulish-bold">test</p>
            <p class="align-right mulish-regular">Lorem ipsum dolor sit amet consectetur adipisicing elit. </p>
        </div>
        <div class="flex flex-col bg-stone-700 text-left p-20">
            <p class="font-bold text-2xl mulish-bold">test</p>
            <p class="align-left mulish-regular">Lorem ipsum dolor sit amet consectetur adipisicing elit. </p>
        </div>
        </div>
    </section>

    <section class="flex flex-col justify-center m-20 mt-10 text-white font-bold gap-4">
        <p class="text-center text-3xl mulish-bold">Més sabors</p><br>
        <div class="flex flex-row justify-center md:gap-10 gap-3 flex-wrap">
			<LlaunaLink
				flavour="mango"
				side="frente"/>
			<LlaunaLink 
				flavour="coco"
				side="frente"/>
			<LlaunaLink
				flavour="pitahaya"
				side="frente"/>
			<LlaunaLink
				flavour="taronja"
				side="frente"/>
			<LlaunaLink
				flavour="uves"
				side="frente"/>
        </div>
    </section>
</Layout>
